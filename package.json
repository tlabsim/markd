{
  "name": "markd",
  "version": "1.0.2",
  "description": "A beautiful, feature-rich desktop markdown viewer and editor",
  "author": {
    "name": "Iftekhar Mahmud Towhid",
    "email": "tlabs.im@gmail.com",
    "url": "https://github.com/tlabsim"
  },
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "npm run build && concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win",
    "dist:store": "npm run generate-store-assets && npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win appx --x64",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:all": "npm run build && electron-builder --win --linux --mac -c.win.signAndEditExecutable=false",
    "dist:win:unsigned": "npm run dist:win",
    "generate-icons": "node scripts/generate-icons.mjs",
    "generate-store-assets": "node scripts/generate-store-assets.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "app-builder-bin": "^4.2.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "katex": "^0.16.9",
    "mermaid": "^11.15.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "remark-directive": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-smartypants": "^3.0.2",
    "remark-wiki-link": "^2.0.1",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.4",
    "to-ico": "^1.1.5",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0",
    "zustand": "^4.5.2"
  },
  "build": {
    "appId": "com.markd.app",
    "productName": "Markd",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/renderer",
        "to": "renderer"
      },
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "compression": "maximum",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/markd.ico",
      "artifactName": "Markd-${version}.${ext}"
    },
    "appx": {
      "identityName": "tlabsim.Markd",
      "publisher": "CN=F44485B2-14EC-4065-A101-2A3C0586F09B",
      "publisherDisplayName": "tlabsim",
      "applicationId": "Markd",
      "displayName": "Markd",
      "backgroundColor": "#f1f2f4",
      "languages": [
        "en-US"
      ],
      "showNameOnTiles": false,
      "artifactName": "Markd-${version}-Store.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/markd.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/markd.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/markd.ico",
      "uninstallerIcon": "resources/markd.ico"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown File",
        "description": "Markd Markdown Document",
        "role": "Viewer"
      },
      {
        "ext": "markdown",
        "name": "Markdown File",
        "description": "Markd Markdown Document",
        "role": "Viewer"
      }
    ]
  }
}
